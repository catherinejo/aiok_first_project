# AIOK Environment Configuration

# Application
APP_NAME=AIOK
# 비우면 pyproject 패키지 버전과 동기(importlib)
# APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1

# CORS: "*" 또는 쉼표 구분 오리진 (운영 예: https://app.example.com,https://admin.example.com)
CORS_ORIGINS=*

# 선택: 설정 시 POST /api/v1/chat 에 Authorization: Bearer <키> 또는 X-API-Key 헤더 필요
# API_KEY=

# Database (Session 저장용) - PostgreSQL 권장
# 설정하지 않으면 InMemorySession 사용 (서버 재시작 시 세션 삭제)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aiok

# Google 인증 (둘 중 하나 선택)

# 옵션 1: Vertex AI (Service Account 인증) - 권장
GOOGLE_APPLICATION_CREDENTIALS=service-account.json
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_LOCATION=us-central1

# 옵션 2: Gemini API (API 키 인증)
# https://ai.google.dev/gemini-api/docs/api-key 에서 발급
# GOOGLE_API_KEY=AIzaSy...

# Google Calendar MCP (선택)
# true로 설정하면 Calendar MCP 활성화
ENABLE_CALENDAR_MCP=false
